#3.简单函数
def is_prime(n):
    if n == 1:
        return False
    else:
        i = 2
        while i <= n:
        #优化为 while i <= n**0.5
            if n % i == 0 and i != n:
                return False
            else:
                i += 1
        if i == n + 1:
            return True    
if is_prime(int(input('请输入一个整数'))) == True:
    print('它是质数')
else:
    print('它不是质数')
prime = []
for j in range(1,101):        
    if is_prime(j) == True:
        prime.append(j)
print(prime)

